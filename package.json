{
  "name": "soultest",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run db:migrate:local && pnpm run db:seed:local && node scripts/dev.mjs",
    "dev:web": "vite --configLoader native",
    "dev:api": "node ./node_modules/wrangler/wrangler-dist/cli.js pages dev dist --port 8788 --compatibility-date=2026-03-13 --d1 SOULTEST_DB --kv SOULTEST_CACHE --r2 SOULTEST_ASSETS --binding APP_ENV=local --binding API_STUB_MODE=d1 --binding ACCESS_TOKEN_TTL_DAYS=30",
    "build": "tsc -b && vite build --configLoader native",
    "lint": "eslint .",
    "preview": "vite preview --configLoader native",
    "db:migrate:local": "node ./node_modules/wrangler/wrangler-dist/cli.js d1 migrations apply SOULTEST_DB --local --config wrangler.jsonc",
    "db:seed:local": "node ./node_modules/wrangler/wrangler-dist/cli.js d1 execute SOULTEST_DB --local --file db/seeds/local.sql --config wrangler.jsonc",
    "cf:typegen": "node ./node_modules/wrangler/wrangler-dist/cli.js types --env-interface CloudflareEnv"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "gsap": "^3.13.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "shadcn": "^4.0.6",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "wrangler": "^4.72.0"
  }
}
